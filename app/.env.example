# GrowFlow - Variables de entorno
# Copiar como .env y completar. NUNCA commitear el .env real.

# --- Supabase (obligatorio) ---
# URL y publishable/anon key de tu proyecto Supabase (cloud o local con `supabase start`)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=tu-publishable-o-anon-key

# --- Atajo de login (opcional) ---
# Permite loguearse con usuario/clave cortos que mapean a un usuario real de Supabase.
# Formato del alias: usuario:clave (ej. admin:admin). Vacio = deshabilitado.
VITE_LOGIN_ALIAS=
VITE_LOGIN_ALIAS_EMAIL=
VITE_LOGIN_ALIAS_PASSWORD=

# --- Chat con IA local (opcional) ---
# URL de un webhook (ej. n8n) que reciba {"messages":[...]} y devuelva {"reply":"..."}.
# Vacio = la seccion de chat queda deshabilitada.
VITE_CHAT_WEBHOOK_URL=

# --- App ---
VITE_APP_NAME=GrowFlow
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development
