# ============================================================================
# GrowFlow — variables de entorno (Vite). Copiá este archivo a `.env` y completá.
# SIN estas variables la app corre en MODO DEMO (datos en localStorage del navegador,
# sin backend ni login). Todo funciona igual para desarrollar la calculadora.
# ============================================================================

# --- Supabase (base de datos: proveedores, precios, perfiles, sustancias) ---
# Si las dejás vacías o con "tu-proyecto", arranca en modo demo automáticamente.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Auto-login opcional (para no tener que loguearse en dev) ---
VITE_LOGIN_ALIAS=
VITE_LOGIN_ALIAS_EMAIL=
VITE_LOGIN_ALIAS_PASSWORD=

# --- Integraciones opcionales (chat IA / OCR / transcripción / knowledge base) ---
# No hacen falta para la Calculadora de Fertilizantes. Dejalas vacías si no las usás.
VITE_CHAT_WEBHOOK_URL=
VITE_OCR_WEBHOOK_URL=
VITE_TRANSCRIBE_WEBHOOK_URL=
VITE_KB_URL=
